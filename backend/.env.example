# ─── Supabase ───────────────────────────────────────────────
# Cada dev usa su PROPIO proyecto Supabase (BD + Google OAuth independientes).
# DATABASE_URL y SUPABASE_URL apuntan al mismo project-ref de ESE dev.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Supabase project URL. De aqui se deriva el JWKS para validar tokens y la
# callback URL de OAuth ({SUPABASE_URL}/auth/v1/callback, se registra en Google).
SUPABASE_URL=https://<project-ref>.supabase.co

# Opcional: JWT secret legacy (HS256). Se usa JWKS (ES256) por defecto.
# SUPABASE_JWT_SECRET=

# Service role key para llamadas server-side (Project Settings > API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=innovacion@elecmetal.cl

# ─── App ────────────────────────────────────────────────────
ENVIRONMENT=development

# Origenes permitidos por CORS. Debe coincidir con el puerto del frontend
# (NEXT_PUBLIC_SITE_URL). Por defecto el dev server corre en :3000.
# Acepta lista separada por comas: http://localhost:3000,http://localhost:3001
CORS_ORIGINS=http://localhost:3000
